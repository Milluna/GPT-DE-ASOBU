{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ES2022"
    ],
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "vitest/globals",
      "node"
    ]
  },
  "include": [
    "tests",
    "src/game/locomotion.ts",
    "src/game/remoteInterpolator.ts",
    "src/game/tauntMotionOverlay.ts",
    "src/types.ts",
    "src/characters.ts"
  ]
}
