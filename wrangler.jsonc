{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "gpt-de-asobu",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-07-12",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/ws/*"]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "TauntRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["TauntRoom"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
